{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/webhook-test/(.*)",
      "dest": "/app.py"
    },
    {
      "src": "/upload",
      "dest": "/app.py"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/app.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1",
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/login.html"
    }
  ]
}
